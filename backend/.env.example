# Banco de dados
POSTGRES_USER=sus
POSTGRES_PASSWORD=sus_search_2025
POSTGRES_DB=sus_search
DATABASE_URL=postgresql://sus:sus_search_2025@db:5432/sus_search

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost

# ETL
DATA_DIR=/app/data
REQUESTS_TIMEOUT=120

# Frontend
VITE_API_URL=

# ──────────────────────────────────────────────────────────────────
# LLM — módulo "Perguntar em linguagem natural"
# Descomente UMA das opções abaixo:
# ──────────────────────────────────────────────────────────────────

# OPÇÃO 1: Groq (recomendado para produção — grátis, rápido, sem GPU)
# Cadastre em: https://console.groq.com  →  API Keys  →  Create API Key
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=llama-3.1-8b-instant
# Modelos Groq disponíveis (todos gratuitos):
#   llama-3.1-8b-instant   (mais rápido)
#   llama-3.1-70b-versatile (mais inteligente, melhor português)
#   llama-3.3-70b-versatile (mais recente)
#   gemma2-9b-it            (Google Gemma 2)
#   mixtral-8x7b-32768      (Mixtral)

# OPÇÃO 2: Ollama local (grátis, sem internet, requer GPU/CPU boa)
# Ativar: docker compose --profile ollama up
# Baixar modelo: docker compose exec ollama ollama pull llama3.2:3b
# LLM_BASE_URL=http://ollama:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.2:3b
# Modelos Ollama recomendados:
#   llama3.2:3b      (leve, 2GB, roda em qualquer Mac)
#   llama3.1:8b      (melhor, 5GB, recomendado para Apple Silicon)
#   phi4-mini        (Microsoft, ótimo raciocínio, 2.5GB)
#   qwen2.5:7b       (excelente português, 4.5GB)

# OPÇÃO 3: Gemini Flash (Google — grátis, ótimo português)
# Cadastre em: https://aistudio.google.com/apikey
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=gemini-2.0-flash

# OPÇÃO 4: OpenAI (pago, mas funciona igual)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=gpt-4o-mini
